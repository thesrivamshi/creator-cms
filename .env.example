# Supabase project (Settings → API in the Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Used by capture endpoints that authenticate via capture token.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 32-byte hex secret for AES-256-GCM encryption of stored AI API keys.
# Generate with: openssl rand -hex 32
# This is deployment infrastructure config — NOT a vendor AI key.
APP_SECRET=generate-me
